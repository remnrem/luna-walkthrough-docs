  sig = AF3
  sig = EEG-AF3
  sig = "AF3 REF"
  ref = "M1,M2","EEG-M1,EEG-M2","M1 REF,M2 REF","A1,A2","EEG-A1,EEG-A2","A1 REF,A2 REF"
