```{ .R .codeR }
ids <- unique( d$ID )
par(mfcol=c(10,2) , mar=c(3,3,1,1) )
for (id  in  ids)
{
 stgs <- d$STAGE[ d$ID == id ]
 times <- d$MINS[ d$ID == id ] * 60
 lhypno( stgs , times = times )
}
