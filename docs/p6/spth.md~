## Individual spindle modal frequencies

```
fchs  <- c( "AFZ","AF3","AF4","FZ","F1","F2","F4","F3") 
cpchs <- c( "CPZ","CP1","CP2","CP3","CP4","PZ","P1","P2","P3","P4" )
fx2 <- fx[ fx >= 7 & fx <= 16 ]
``` 

```
ssf <- fsf <- numeric(0)
for (id in ids ) {
 xx <- d[ d$ID == id & d$F %in% fx2 & d$CH %in% fchs , ] 
 ssf <- c(ssf, mean( fx2[ tapply( xx$PER, xx$CH, function(x) { which(max(x) == x ) } ) ] ) )
 xx <- d[ d$ID == id & d$F %in% fx2 & d$CH %in% cpchs , ] 
 fsf <- c(fsf, mean( fx2[ tapply( xx$PER, xx$CH, function(x) { which(max(x) == x ) } ) ] ) )
}
```

```
cbind( ids , ssf, fsf )
```

Females:
```
par(mfcol=c(5,2) , mar=c(3,1,1,0.5) )
for (id  in ids[1:10] ) {
 xx <- d[ d$ID == id , ]
 plot( fx , fx , type="n" , xlab = "Frequency (Hz)" , ylab = "Power" , ylim = range( d$PER ) , main = id  )
 for (ch  in 1:nchs)
   lines( fx , xx$PER[ xx$CH == chs[ch] ] ,  col = pal[ch] , lwd=1 )
 pf <- fsf[ which( ids == id ) ] 
 abline(v=c(pf-2,pf))
}
```

Males:
```
par(mfcol=c(5,4) , mar=c(3,1,1,0.5) )
for (id  in ids[11:20] ) {
 xx <- d[ d$ID == id , ]
 plot( fx , fx , type="n" , xlab = "Frequency (Hz)" , ylab = "Power" , ylim = range( d$PER ) , main = id  )
 for (ch  in 1:nchs)
   lines( fx , xx$PER[ xx$CH == chs[ch] ] ,  col = pal[ch] , lwd=1 )
