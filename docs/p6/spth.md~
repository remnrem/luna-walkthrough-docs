```
df <- data.frame( ID = ids , SSF = fsf - 2 , FSF = fsf )
write.table( df, file = "spindle-freqs.txt" , col.names=T , row.names=F, quote=F , sep="\t" )
```

Re-run spindle detection:

```
luna c.lst id=M01 \
  vars=spindle-freqs.txt \
  -o  out/indiv-spindles.db \
  -s ' MASK ifnot=N2 & RE
       CHEP-MASK sig=${eeg} ep-th=3,3
       CHEP sig=${eeg} epochs & RE
       TAG stype/SS
       SPINDLES sig=${eeg} fc=${SSF} cycles=18 q=-9 so mag=2 nreps=1000
       TAG stype/FS
       SPINDLES sig=${eeg} fc=${FSF} cycles=18 q=-9 so mag=2 nreps=1000 '
```

